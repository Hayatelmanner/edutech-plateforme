# ============================================
#  CONFIGURATION DU BACKEND EDUTECH
# ============================================
#  Copiez ce fichier en .env et remplissez les valeurs réelles
#  Le fichier .env NE DOIT JAMAIS être committé sur GitHub
# ============================================

# Port du serveur
PORT=5000

# Base de données MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=edutech_db
DB_PORT=3306

# JWT (clé secrète pour les tokens)
# Générer une clé forte : https://www.allkeysgenerator.com/
JWT_SECRET=changez_moi_par_une_cle_secrete_longue_et_aleatoire
JWT_EXPIRES_IN=7d

# URL du frontend (pour CORS)
FRONTEND_URL=http://localhost:5173

# Mode (development | production)
NODE_ENV=development